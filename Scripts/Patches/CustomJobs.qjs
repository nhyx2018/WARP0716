///
/// \brief: Change the Hardcoded loading & retrieval of Job strings (Name, Path prefix,
///         Hand prefix, Palette prefix & Imf Prefix?) to use Lua functions.
///         Similarly update the sprite size checker & Mount retrieval functions as well.
///
CustomJobs = function(_)
{
	$$(_, 1.1, `Ensure the 'Translate Taekwon' patch is unselected. Not applicable for test mode`)
	if (!Warp.TestMode)
		Warp.SetPatchState("TranslateTaekwon", false);

	$$(_, 1.15, `07-16 build-specific: bypass generic pattern matching`)
	if (Exe.BuildDate >= 20250700)
		return this.apply0716(_);

	//=====================================================//
	// Find the table loading area (references to strings) //
	//=====================================================//

	if (!CACHE.has('CJ_Infos'))
	{
		let refs = [];

		$$(_, 1.2, `Find the spr/act path suffix for Santa costume`)
		let strAddr = Exe.FindText("\xBB\xEA\xC5\xB8");
		if (strAddr < 0)
			throw Error("Santa is missing");

		$$(_, 1.3, `Find it's references (there should only be 1) and add to [refs] array`)
		let addrs = Exe.FindHexN(MOV([R32, 0x68], strAddr)); //mov dword ptr [regA + 68h], offset "»êÅ¸"
		if (ROC.IsZero && addrs.length > 1)
		{
			const addr = addrs.find( memAddr =>
				Exe.FindLastHex(PUSH(0x10AA) + MOV(ECX, ESI), memAddr, memAddr - 0x800) < 0
			);
			if (!addr)
				throw Error("Santa reference missing");

			refs[0] = addr;
		}
		else if (addrs.length === 1)
		{
			refs[0] = addrs[0];
		}
		else
		{
			throw Error("Unexpected no of Santa references");
		}

		$$(_, 1.4, `Find the imf suffix for Groom/Bride (used for Santa as well) and add to [refs] array`)
		strAddr = Exe.FindText("\xB0\xE1\xC8\xA5"); //"°áÈ¥"
		if (strAddr < 0)
			throw Error("Groom/Bride is missing");

		addrs = Exe.FindHexN(1, 1, MOV([R32, 0x68], strAddr)); //mov dword ptr [regA + 68h], offset "°áÈ¥"
		if (addrs.isEmpty())
			throw Error("Expected exactly 1 Wedding reference");

		refs[1] = addrs[0];

		$$(_, 1.5, `Find the palette suffix for Archer`)
		strAddr = Exe.FindText("\xB1\xC3\xBC\xF6"); //"±Ã¼ö"
		if (strAddr < 0)
			throw Error("Archer is missing");

		if (Exe.Version === 6)
		{
			$$(_, 1.6, `For VC6 find it's reference after a PUSH 4`)
			addrs = Exe.FindHexN(MOV([EAX], strAddr) + CALL()); // mov dword ptr [eax], offset "±Ã¼ö"
																// call <fetcher>

			const code2 = PUSH(4); //PUSH 4 should be present before

			const addr = addrs.find( memAddr =>
				Exe.FindLastHex(code2, memAddr, memAddr - 0x6) > 0
			);
			if (!addr)
				throw Error("Archer reference missing (VC6)");

			refs[2] = addr;
		}
		else
		{
			$$(_, 1.7, `For VC9+ find all references with direct movement to table`)
			addrs = Exe.FindHexN(MOV([R32, 0xC], strAddr)); //mov dword ptr [regA + 0Ch], offset "±Ã¼ö"

			const addr = addrs.find( memAddr =>
				!refs.some(refAddr => memAddr >= (refAddr - 0x300) && memAddr <= (refAddr + 0x300))
			);
			if (!addr)
				throw Error("Archer reference missing (VC9+)");

			refs[2] = addr;
		}

		$$(_, 1.8, `Find the hand prefix for Archer`)
		strAddr = Exe.FindText("\xB1\xC3\xBC\xF6\\\xB1\xC3\xBC\xF6"); // ±Ã¼ö\±Ã¼ö for Archer
		if (strAddr < 0)
			throw Error("Hand prefix missing");

		$$(_, 1.9, `Find it's reference`)
		refs[3] = Exe.FindHex(MOV([R32, 0xC], strAddr)); //mov dword ptr [regA + 0Ch], offset "±Ã¼ö\±Ã¼ö"
		if (refs[3] < 0)
			throw Error("Hand reference missing");

		$$(_, 1.10, `Find the string 'Acolyte'`)
		strAddr = Exe.FindText("Acolyte"); //We use Acolyte here because Archer has a ( mov ecx, offset ) instruction before it in Older clients
		if (strAddr < 0)
			strAddr = Exe.FindText("ACOLYTE"); // 07-16 uses ALL UPPERCASE job names
		if (strAddr < 0)
			throw Error("Acolyte is missing");

		$$(_, 1.11, `Find it's reference`)
		refs[4] = Exe.FindHex(MOV([R32, 0x10], strAddr)); //mov dword ptr [regA + 10h], offset "Acolyte"
		if (refs[4] < 0)
			throw Error("Acolyte reference missing");

		//==========================================================================================//
		// Find the hook & end address for table loading & extract all non-related codes in between //
		//==========================================================================================//

		$$(_, 2.1, `Ensure LANGTYPE is loaded . Needed by FetchTillEnd`)
		LANGTYPE.load();

		let limits = Exe.BuildDate >= 20250700
		? [
			0x6D95,
			0x6D95,
			0x6D95,
			0x6D95,
			0x110A
		]
		: Exe.BuildDate >= 20170700
		? [
			0x6D93,
			0x6D93,
			0x6D93,
			0x6D93,
			0x7D01
		]
		: [
			0x524C,
			0x524C,
			0x524C,
			0x524C,
			0x61BA
		]
		;

		let fetcher = -1;
		const infos = refs.map( (addr, idx) =>
		{
			$$(_, 2.2, `Prep variables for required info`)
			let hookAddr, movIns, baseReg, format; //baseReg contains address for index 0 of the table, movIns will contain the mov to baseReg

			$$(_, 2.3, `Find the limit usage before it`)
			const limitAddr = Exe.FindLastHex(limits[idx].toHex(), addr, addr - 0x800);
			if (limitAddr < 0)
				throw Error(`Limit missing for no.${idx + 1}`);

			$$(_, 2.4, `Extract the instruction after the reference`)
			let ins = Instr.FromAddr(addr).moveToNext();
			if (ins.Codes[0] === 0xE8) //VC6
			{
				$$(_, 2.5, `Since there is no mov unset movIns`)
				movIns = null;

				$$(_, 2.6, `Calculate the CALL's address if not already found`)
				if (fetcher < 0)
					fetcher = Exe.Phy2Vir(ins.NextAddr, CODE) + ins.Immd; //the target VIRTUAL address

				$$(_, 2.7, `Find the address for the first table assignment`)
				const code =
					PUSH_0         //push 0
				+	MOV(ECX, ESI)  //mov ecx, esi
				+	CALL(ALLWC)    //call func#1
				;
				const firstAddr = Exe.FindHex(code, limitAddr + 4, limitAddr + 0x60);
				if (firstAddr < 0)
					throw Error(`First index assignment missing for no.${idx + 1}`);

				$$(_, 2.8, `Set the hook address after the CALL & set the base register`)
				hookAddr = firstAddr + code.byteCount();
				baseReg = EAX;
				format = 0;
			}
			else if (ins.Codes[0] === 0x8B && ins.MRM.Mode !== 3) //VC9+
			{
				$$(_, 2.9, `Set it as the mov instruction`)
				movIns = ins;

				$$(_, 2.10, `Extract the register used as source in mov tgtReg, dword ptr [srcReg + Disp]`)
				const srcReg = ins.MRM.getReg('M');

				$$(_, 2.11, `Use it to construct the table assignment pattern & look for it after the limitAddr`)
				const prefix = MOV(R32, ins.Disp ? [srcReg, ins.Disp] : [srcReg]);
				const addrs = [
					...Exe.FindHexN(1, prefix + MOV([R32], POS3WC), limitAddr + 4, limitAddr + 0x60),        //mov dword ptr [regA], offset#1
					...Exe.FindHexN(1, prefix + MOV([R32, WCp], POS3WC), limitAddr + 4, limitAddr + 0x60),   //mov dword ptr [regA + disp8], offset#1
					...Exe.FindHexN(1, prefix + MOV([R32, POS2WC], POS3WC), limitAddr + 4, limitAddr + 0x60) //mov dword ptr [regA + disp32], offset#1
				].sort();

				if (addrs.isEmpty())
					throw Error(`Starting index assignment missing for no.${idx + 1}`);

				$$(_, 2.12, `Hook at the location after the smallest`)
				hookAddr = addrs[0] + movIns.Size;

				$$(_, 2.13, `Use the next byte to calculate the base register`)
				baseReg = R32.List[Exe.GetInt8(hookAddr + 1) & 0x7];
				format = 1;
			}
			else
				throw Error(`Unexpected opcode for no.${idx + 1}`);

			$$(_, 3.1, `Now find the ending instruction while extracting all relevant instructions (not related to table loading) in between`)
			let [endIns, retainer, overflow] = FetchTillEnd(hookAddr, format, movIns, baseReg, fetcher, (ins) =>
			{
				if (Exe.Version === 6) //VC6
				{
					switch (ins.Codes[0])
					{
						case 0x8D:
							if (ins.MRM.Mode === 2) //lea regA, [regB + dispB]
							{
								return (Exe.GetUint16(ins.NextAddr) === 0x45C7); //followed by ( mov dword ptr [LOCAL.x], offset#1 )
							}
							else if (ins.MRM.Mode === 1) //lea regA, [LOCAL.y]
							{
								let bytes = Exe.GetUint16(ins.NextAddr);

								return (bytes === 0xB38D || //followed by ( add regA, immA )
										bytes === 0xC381 || //or by       ( lea regA, [regB + dispB] )
										bytes === 0x5588 ); //or by       ( mov byte ptr [LOCAL.x], dl )
							}
							break;

						case 0x8B: //mov eax, dword ptr [edi+4]
							return (ins.MRM.Data === 0x47 && ins.Disp === 4);
					}
				}
				else if (Exe.Version <= 10) //VC9 & VC10
				{
					switch (ins.Codes[0])
					{
						case 0x2B: //sub regA, regB
							return (ins.MRM.Mode === 3 && (Exe.GetInt32(ins.Addr + 2) & 0xFFF8FF) === 0x02F8C1); //followed by ( sar regA, 2 )

						case 0x83: //or regA, -1
							return (ins.MRM.RegO === 1 && ins.Immd === -1);

						case 0xFF: //call dword ptr [funcPtr#1] //hopefully wont conflict later
							return (ins.MRM.Data === 0x15);
					}
				}
				else //VC11+
				{
					switch (ins.Codes[0])
					{
						case 0x8D:
							if (ins.MRM.Mode === 1 && ins.MRM.RegO === 0 && Exe.GetUint8(ins.NextAddr) === 0x50) //lea eax, [LOCAL.x]
							{                                                                                    //push eax
								let opcode = Exe.GetUint8(ins.NextAddr + 1);

								return (opcode === 0x6A || //followed by ( push immA )
										opcode === 0x68 ||
										opcode === 0x56 ); //or by ( push esi )
							}
							break;

						case 0x8B:
							if (ins.MRM.Mode === 0 && ins.MRM.RegO === 0) //mov eax, dword ptr [regA]
							{
								return (Exe.GetUint16(ins.NextAddr) === 0x048D); //followed by ( lea eax, [regB*4 + eax] )
							}
							break;

						case 0xE8: //stop at the CALL
							return true;
					}
				}
				return false;
			});
			if (overflow)
				throw Error(`Table end missing for no.${idx+1}`);

			$$(_, 3.2, `Return the set`)
			return [hookAddr, baseReg, endIns, retainer];
		});

		CACHE.put('CJ_Infos', infos);
	}

	$$(_, 4.1, `Get the new max limit from user`)
	const MaxJob = Exe.GetUserInput('$maxJob', D_Uint16, "Limit Input", "Enter the maximum no of Job IDs", 4500, {min: 4400, max: 10000, saveDefault: true});
	if (MaxJob === false)
		Cancel("No Max Limit specified");

	//====================================//
	// Add the Function Names into client //
	//====================================//

	$$(_, 4.2, `Insert the Lua function names into the client (Since we wont be using the hardcoded JobNames, we will overwrite suitable ones and use their addresses)`)
	const ReqFuncs =
	[
		this.overwrite("Professor",     "ReqPCPath"    ),
		this.overwrite("Swordman",      "ReqPCImf"     ),
		this.overwrite("Magician",      "ReqPCPal"     ),
		this.overwrite("Swordman High", "ReqPCHandPath"),
		this.overwrite("Baby Acolyte",  "ReqPCJobName" ),
	];
	const MapFuncs =
	[
		this.overwrite("Whitesmith",    "MapPCPath"    ),
		this.overwrite("Assassin",      "MapPCImf"     ),
		this.overwrite("Crusader",      "MapPCPal"     ),
		this.overwrite("Magician High", "MapPCHandPath"),
		this.overwrite("High Wizard_W", "MapPCJobName" ),
	];
	const AltFuncs =
	[
		this.overwrite("High Priest_W", "GetPCNameOvrd"),
		this.overwrite("Alchemist",     "GetHalter"    ),
		this.overwrite("Acolyte",       "IsDwarf"      ),
		this.overwrite("High Wizard",   "GetSprScale"  ),
	];

	$$(_, 4.3, `Get the stored infos`)
	const infos = CACHE.get('CJ_Infos');

	//=======================================//
	// Add Table Loaders using LUA functions //
	//=======================================//

	$$(_, 5.1, `Ensure LUA object is loaded`)
	LUA.load();

	let fileHookAddr, //location where the file loading code will be placed
	    ddd2sAddr;    //location for the "ddd>s" format string
	[
		"PCPath",
		"PCImf",
		"PCPal",
		"PCHandPath",
		"PCJobName"
	].forEach( (fnSuffix, index) =>
	{
		$$(_, 5.2, `Setup the limits for ${fnSuffix}`)
		const reductor = (index === 4) ? 0 : 3950;
		const limits =
		[
			[0, 0x2C],
			[0xFA1 - reductor, MaxJob - reductor]
		];

		$$(_, 5.3, `Generate the templates first`)
		const templates = this.generate(
			[["Req" + fnSuffix, ReqFuncs[index]], "dd>s", EDI, [LANGTYPE], EAX],
			index === 4 //PCJobName
		?
			null //dont call Map for JobName since it is done later anyways (avoid redundancy)
		:
			[["Map" + fnSuffix, MapFuncs[index]], "dd>d", EDI, [LANGTYPE], EAX]
		,
			[ESP, 0x24]
		);

		$$(_, 5.4, `Retrieve the info for this index`)
		const [hookAddr, baseReg, endIns, retainer] = infos[index];

		$$(_, 5.5, `Combine & construct the replacement code in parts`)
		let parts =
		[
			PUSH(baseReg)  //push <baseReg> ; contains address of first index in table
		+	PUSHAD         //pushad
		];

		for (const template of templates)
		{
			for (const [min, max] of limits)
			{
				parts.push( SwapFillers( template,
				{
					1 : min,
					2 : max
				}));
			}
		}

		parts.push(
			POPAD            //popad
		+	ADD(ESP, 4)      //add esp, 4
		);

		if (retainer)
			parts.push(retainer); //codes to be retained from original

		if (endIns)
			parts.push(JMP(Filler(3))); //jmp endAddr ; address of endIns

		$$(_, 5.6, `Fill in the blanks`)
		let code = LUA.finalize(parts, Exe.Phy2Vir(hookAddr, CODE),
		{
			3 : endIns ? Exe.Phy2Vir(endIns.Addr, CODE) : ''
		});

		$$(_, 5.7, `Replace at hook address`)
		Exe.SetHex(hookAddr, code);

		if (index === 4)
		{
			$$(_, 5.8, `Save the location afterwards to use for file loading (picked name table loader since it is the largest)`)
			fileHookAddr = hookAddr + code.byteCount();
		}
	});

	//=========================//
	// Inject Lua file loading //
	//=========================//

	$$(_, 5.9, `Use the address found earlier to add code for loading the files`)
	LUA.addLoaders(
		[
			"Lua Files\\JobInfo\\PCIds",
			"Lua Files\\JobInfo\\PCPaths",
			"Lua Files\\JobInfo\\PCImfs",
			"Lua Files\\JobInfo\\PCHands",
			"Lua Files\\JobInfo\\PCPals",
			"Lua Files\\JobInfo\\PCNames",
			"Lua Files\\JobInfo\\PCFuncs"
		],
		"Lua Files\\DataInfo\\NPCIdentity",
		fileHookAddr
	);

	//============================================================================//
    // Find Gender based Name assignment & Setup extra table assignment for names //
    //============================================================================//

	limits =
	[
		[0, 0x2C],
		[0xFA1, MaxJob]
	];

	$$(_, 6.1, `Find the string 'TaeKwon Girl'`)
	let tgAddr = Exe.FindText("TaeKwon Girl");
	if (tgAddr < 0)
		tgAddr = Exe.FindText("TAEKWON"); // 07-16 uses UPPERCASE, no gender-specific names
	if (tgAddr < 0)
		throw Error("'TaeKwon Girl' not found");

	if (Exe.BuildDate < 20190800 || (!ROC.IsRenewal && Exe.BuildDate < 20190810)) //Older form - Seperate function is called each time the character selection changes
	{
		$$(_, 6.2, `Find where it's referenced`)
		let parts;
		if (Exe.Version < 11)
		{
			parts =
			[
				TEST(EAX, EAX)          //test eax, eax
			+	JNZ(WCp)                //jnz short _skip
			,
				MOV(Exe.Version === 9 && Exe.BuildDate < 20110300 ? R32 : EAX, [POS4WC]) //mov regA, dword ptr [g_jobName]
			,
				MOV([R32, 0x3F38], tgAddr)  //mov dword ptr [regA + 3F38h], offset "TaeKwon Girl"
			];
		}
		else if (Exe.BuildDate < 20170000)
		{
			parts =
			[
				''
			,
				MOV(EAX, [POS4WC])      //mov eax, dword ptr [g_jobName]
			,
				MOV(R32, tgAddr)        //mov regB, offset "TaeKwon Girl"
			+	MOV(R32, POS4WC)        //mov regC, offset "TaeKwon Boy"
			+	CMOVNZ(R32, R32)        //cmovnz regC, regB
			+	MOV([EAX, 0x3F38], R32) //mov dword ptr [eax + 3F38h], regC
			];
		}
		else
		{
			parts =
			[
				TEST(R32, R32)          //test regA, regA
			+	(Exe.Version > 11
			?
				MOV(R32, POS4WC)        //mov regC, offset "TaeKwon Boy"
			:
				''
			)
			+	MOV(R32, tgAddr)        //mov regB, offset "TaeKwon Girl"

			+	CMOVNZ(R32, R32)        //cmovnz regC, regB
			,
				MOV(EAX, [POS4WC])      //mov eax, dword ptr [g_jobName]
			,
				POP_R                   //pop regD
			+	MOV([EAX, 0x3F38], R32)	//mov dword ptr [eax + 3F38h], regC
			];
		}

		let addr = Exe.FindHex(parts);
		if (addr < 0)
			throw Error("'TaeKwon Girl' not assigned");

		$$(_, 6.3, `Extract the g_jobName address`)
		const JobName = Instr.FromAddr(addr + parts.byteCount(0)).Disp;

		$$(_, 6.4, `Look for the LANGTYPE comparison before it (in fact the JNZ should jump to a call after which we do the above TEST)`)
		///       (These steps are also done in TranslateClient but we will keep it anyways as a failsafe)
		let code;
		if (Exe.Version >= 9 && Exe.BuildDate < 20170000)
		{
			code =
				CMP([LANGTYPE], 0)     //cmp dword ptr [g_serviceType], 0
			+	MOV(ECX, POS3WC)       //mov ecx, offset#1
			+	JNE(WCp)               //jne short _skip
			;
		}
		else
		{
			code =
				MOV(EAX, [LANGTYPE])   //mov eax, dword ptr [g_serviceType]
			+	(Exe.Version === 6
			?
				MOV(ECX, POS3WC)       //mov ecx, offset#1
			:
				''
			)
			+	TEST(EAX, EAX)         //test eax, eax
			+	JNZ(WCp)               //jnz short _skip
			;
		}
		addr = Exe.FindHex(code, addr - 0xA0, addr);
		if (addr < 0)
			throw Error("Langtype Comparison missing");

		$$(_, 6.5, `Enforce the conditional jump`)
		addr += code.byteCount();
		Exe.SetJMP(addr - 2);

		$$(_, 6.6, `Go to the target address of the jump (serves as the hookAddr)`)
		let hookAddr = addr + Exe.GetInt8(addr - 1);

		$$(_, 6.7, `Extract the instruction there & check the opcode to extract info for the next step`)
		let genderReg, endAddr, pushes;
		let ins = Instr.FromAddr(hookAddr);
		if (ins.Codes[0] === 0xE8)
		{
			$$(_, 6.8, `If the instruction at the address is CALL CSession::GetSex then EAX will have the gender value.`)
			genderReg = EAX;
			hookAddr += 5;

			$$(_, 6.9, `Find the LANGTYPE comparison after the address`)
			code =
				CMP(EAX, 0xC) //cmp eax, 0Ch
			+	JE(WCp)       //je short _idxInc
			+	CMP(EAX, 5)   //cmp eax, 5
			+	JE(WCp)       //je short _idxInc

			+	(Exe.Version > 11.0
			?
				CMP(EAX, 0xE) //cmp eax, 0Eh
			+	JE(WCp)       //je short _idxInc
			:
				''
			)
			+	CMP(EAX, 6)   //cmp eax, 6
			;

			addr = Exe.FindHex(code, hookAddr + 0x10, hookAddr + 0x100);
			if (addr < 0)
				throw Error("2nd Langtype Comparison missing");

			$$(_, 6.10, `Extract the previous 2 bytes and test for PUSH reg instructions`)
			pushes = Exe.GetBytes(addr - 2, 2);

			if (pushes[0] < 0x50 || pushes[0] > 0x57)
				pushes[0] = 0x90;

			if (pushes[1] < 0x50 || pushes[1] > 0x57)
				pushes[1] = pushes[0] === 0x90 ? 0x56 : 0x90;

			$$(_, 6.11, `Goto the address after the last comparison (should be a JNE)`)
			addr += code.byteCount();

			$$(_, 6.12, `Goto the target address of the JNE`)
			ins = Instr.FromAddr(addr);
			if (ins.Codes[0] === 0x75 || ins.Codes[1] === 0x85)
				addr = ins.NextAddr + ins.Immd;
			else
				throw Error("Expected JNE but it's missing");

			$$(_, 6.14, `Check for the second JNE after 3 bytes (CMP EAX, 0A) and retrieve it's target PHYSICAL address`)
			if (Exe.GetUint16(addr + 3) === 0x850F)
				endAddr = Exe.GetTgtAddr(addr + 5);
			else
				throw Error("2nd JNE missing");
		}
		else if (ins.Codes[0] === 0x83 && ins.MRM.Data === 0xF8) //newer clients (2017+)
		{
			$$(_, 6.15, `The comparison is at the address itself, which means the gender was provided as argument and assigned to EDI earlier`)
			genderReg = EDI;
			pushes = [];
		}
		else
		{
			throw Error("Unexpected instruction found");
		}

		$$(_, 6.16, `Generate the templates to be used`)
		const templates = this.generate(
			[["GetPCNameOvrd", AltFuncs[0]], "ddd>s", EDI, ESI, [LANGTYPE], EAX],
			[["MapPCJobName",  MapFuncs[4]], "dd>d",  EDI, [LANGTYPE], EAX],
			[JobName]
		);

		$$(_, 6.17, `Construct the code in parts`)
		parts = pushes.map(opcode => opcode.toHex(1)); //set of PUSH reg32 which need to be retained since they are POPed out later

		parts.push(
			PUSHAD
		+	MOV(ESI, genderReg)
		);

		for (const template of templates)
		{
			for (const [min, max] of limits)
			{
				parts.push( SwapFillers( template,
				{
					1 : min,
					2 : max
				}));
			}
		}

		parts.push(
			POPAD                //popad
		);

		if (endAddr)
		{
			parts.push(JMP(Filler(3))); //jmp <endAddr>
		}
		else
		{
			parts.push(
				POP(EDI)         //pop edi
			+	POP(EBP)         //pop ebp
			+	RETN(4)          //retn 4
			);
		}

		$$(_, 6.18, `Fill in the blanks`)
		const hookVir = Exe.Phy2Vir(hookAddr, CODE);

		code = LUA.finalize( parts, hookVir,
		{
			3 : endAddr
		});

		$$(_, 6.19, `Replace at hook address`)
		Exe.SetHex(hookAddr, code);
	}
	else //Newer form - Name overrides are setup along with the regular loading and it uses a seperate function for it
	{
		$$(_, 7.1, `Retrieve the address after the ending instruction for the name table loading (ideally would be a CALL)`)
		const [,,endIns] = infos.last();
		const hookAddr = endIns.NextAddr;

		$$(_, 7.2, `Find the ECX assignment after it`)
		let addr = Exe.FindHex(LEA(ECX, [EBX, POS2WC]), hookAddr, hookAddr + 0x30); //lea ecx, [ebx + dispA]

		if (addr < 0 && Exe.BuildDate > 20210000)
			addr = Exe.FindHex(MOV(ECX, EDI), hookAddr, hookAddr + 0x30);

		if (addr < 0)
			throw Error("Object assignment missing");
		
		$$(_, 7.3, `Save the instruction`)
		const ecxAssign = Instr.FromAddr(addr);

		$$(_, 7.4, `Find the table assignment before hookAddr`)
		addr = Exe.FindLastHex( MOV(R32, [R32]) + MOV([R32, POS2WC], POS4WC), hookAddr, hookAddr - 0x100);
		if (addr < 0)
			throw Error("Table assignment missing");

		$$(_, 7.5, `Extract the memory register used`)
		const tblReg = Instr.FromAddr(addr).MRM.getReg('M');

		$$(_, 7.6, `Find the string assignment to stack location`)
		addr = Exe.FindHex(MOV([EBP, WCn], tgAddr), hookAddr, hookAddr + 0x90);  //mov dword ptr [LOCAL.x], offset "TaeKwon Girl"
		if (addr < 0)
			throw Error("Taekwon girl not referenced");

		$$(_, 7.7, `Save the stack location used`)
		const strLoc = [EBP, Instr.FromAddr(addr).Disp];

		$$(_, 7.8, `Find the index assignment to stack location`)
		addr = Exe.FindHex(MOV([EBP, WCn], 0xFD2), hookAddr, hookAddr + 0x90); //mov dword ptr [LOCAL.x], 0FD2h
		if (addr < 0)
			throw Error("Index PUSH missing");

		$$(_, 7.9, `Save the stack location used`)
		const idxLoc = [EBP, Instr.FromAddr(addr).Disp];

		$$(_, 7.10, `Find the additional stack location PUSH after it (not sure why it is needed)`)
		let parts =
		[
			LEA(EAX, [EBP, WCn]) //lea eax, [LOCAL.y]
		,
			''
		,
			PUSH_EAX             //push eax
		];

		let addr2 = Exe.FindHex(parts, addr + 8, hookAddr + 0x30);
		if (addr2 < 0)
		{
			parts[1] = ecxAssign.toString();
			addr2 = Exe.FindHex(parts, addr + 8, hookAddr + 0x30);
		}
		const csize = parts.byteCount();

		if (addr2 > 0)
		{
			const disp = Instr.FromAddr(addr2).Disp;
			if (disp === idxLoc[1] || disp === strLoc[1]) //this is the wrong PUSH, so search again
				addr2 = Exe.FindHex(parts, addr2 + csize, hookAddr + 0x30);
		}
		if (addr2 < 0)
			throw Error("Mem PUSH missing");

		$$(_, 7.11, `Save the instructions`)
		const pushMEM = Exe.GetHex(addr2, parts.byteCount(0)) + PUSH_EAX;

		$$(_, 7.12, `Look for the function CALL after the PUSH (either its directly after or the LEA is in between)`)
		addr = addr2 + csize;
		if (addr === ecxAssign.Addr)
			addr = ecxAssign.NextAddr;

		let ins = Instr.FromAddr(addr);
		if (ins.Codes[0] !== 0xE8) //a mov dword ptr instruction can also come in between
			ins.moveToNext();

		if (ins.Codes[0] !== 0xE8)
			throw Error("Function CALL missing");

		$$(_, 7.14, `Retrieve the target VIRTUAL address`)
		const Overrider = Exe.Phy2Vir(ins.NextAddr + ins.Immd, CODE);

		$$(_, 7.15, `Find the ending address of the table`)
		addr = Exe.FindHex(MOV(R32, 0x2D) + NOP2, addr + 0x200, addr + (Exe.BuildDate > 20211000 ? 0x1000 : 0x400));
		if (addr < 0)
			throw Error("Ending address missing for new overrides");

		const endVir = Exe.Phy2Vir(addr, CODE);

		$$(_, 7.16, `Construct the template (the first one need to be done manually since the way we code is different)`)
		const templates = this.generate(
			null,
			[["MapPCJobName", MapFuncs[4]], "dd>d", EDI, [LANGTYPE], EAX],
			[ESP, 0x24]
		);

		const [    , mainM,        ] = LUA.createCaller(["GetPCNameOvrd", AltFuncs[0]], "ddd>s", EDI, 1, [LANGTYPE], EAX);
		const [prep, mainF, restore] = LUA.createCaller(["GetPCNameOvrd", AltFuncs[0]], "ddd>s", EDI, 0, [LANGTYPE], EAX);

		parts =
		[//0
			MOV(EDI, Filler(1))      //mov edi, <startingValue> ; serves as idx
		+	MOV(ESI, Filler(2))      //mov esi, <endingValue>
		+	prep                     //Stack Prep

		,//1
			mainM                    //LUA function caller for Male ; _loop
		+	MOV(CL, [EAX])           //mov cl, dword ptr [eax]
		+	TEST(CL, CL)             //test cl, cl
		+	JE(7)                    //je short _skip
		+	MOV(ECX, [ESP, 0x24])    //mov ecx, dword ptr [esp+24h] ; table address
		+	MOV([4, EDI, ECX], EAX)  //mov dword ptr [4*edi + ecx], eax

		+	mainF                    //LUA function caller for Female ; _skip
		+	MOV(CL, [EAX])           //mov cl, dword ptr [eax]
		+	TEST(CL, CL)             //test cl, cl
		+	JE(Filler(6,1))          //je short _idxInc
		+	MOV(strLoc, EAX)         //mov dword ptr [LOCAL.z], eax

		+	MOV(ECX, [ESP, 0x28])    //mov dword ptr ecx, [esp+28h] ; object address
		+   PUSH_EAX                 //push eax   ; the name
		+	LEA(EAX, idxLoc)         //lea eax, [LOCAL.x]
		+	MOV([EAX], EDI)          //mov dword ptr [eax], edi
		+	PUSH_EAX                 //push eax   ; the index location
		+	PUSH_0                   //push 0
		+	pushMEM                  //lea eax, [LOCAL.y]
			                         //push eax   ; the mem location
		+	CALL(Filler(4))          //call <Overrider>

		,//2
			INC(EDI)                 //inc edi ; _idxInc
		+	CMP(EDI, ESI)            //cmp edi, esi
		+	JLE(Filler(5))           //jle _loop ; to start of the first 'main' code i.e. mainM
		+	restore                  //Stack restore
		];

		const [,_loop, _idxInc] = MapAddrs(0, parts);

		templates[0] = SetFillTargets( parts, 1,
		{
			 5    : _loop,
			'6,1' : _idxInc
		});

		$$(_, 7.17, `Construct the code in parts`)
		parts =
		[
			ecxAssign      //either lea OR mov to ecx
		+	PUSH(ECX)      //push ecx
		+	PUSH([tblReg]) //push dword ptr [edi] or [esi] ; table address
		+	PUSHAD         //pushad
		];

		for (const template of templates)
		{
			for (const [min, max] of limits)
			{
				parts.push( SwapFillers( template,
				{
					1 : min,
					2 : max
				}));
			}
		}

		parts.push(
			POPAD            //popad
		+	ADD(ESP, 8)      //add esp, 8
		+	JMP(Filler(3))   //jmp <endVir>
		);

		$$(_, 7.18, `Fill in the blanks`)
		const hookVir = Exe.Phy2Vir(hookAddr, CODE);

		const code = LUA.finalize(parts, hookVir,
		{
			3 : endVir,
			4 : Overrider
		});

		$$(_, 7.19, `Replace at hook address`)
		Exe.SetHex(hookAddr, code);
	}

	//============================//
    // Special Mod 1 : Cash Mount //
    //============================//

	if (Exe.BuildDate > 20101214)
	{
		$$(_, 8.1, `Find the function whre the Mount ID is assigned`)
		const code =
			CMP(EAX, 0x19)   //cmp eax, 19h
		+	JNE(WCp)         //jne short _skip
		+	MOV(EAX, 0x1012) //mov eax, 1012h
		;
		const addr = Exe.FindHex(code);
		if (addr < 0)
			throw Error("Mount assignment missing");

		$$(_, 8.2, `Construct the LUA caller code`)
		const [prep, main, restore] = LUA.createCaller(["GetHalter", AltFuncs[1]], "d>d", EAX, EAX);

		$$(_, 8.3, `Replace at the address`)
		Exe.SetHex( addr
		,
			LUA.finalize(
				PUSH(EDX)  //Backup EDX
			+	prep       //Stack Prep
			+	main       //LUA function CALL
			+	restore    //Stack Restore
			+	POP(EDX)   //Restore EDX
			+	(ROC.HasFP
			?
				POP(EBP)   //pop ebp
			:
				''
			)
			+	RETN(4)    //retn 4
			,
				Exe.Phy2Vir(addr, CODE)
			)
		);
	}

    //================================================//
    // Special Mod 2 : Baby Jobs (Tester & Shrink) //
    //================================================//

	$$(_, 9.1, `Identify the style based on dates`)
	const style =
		         Exe.Version > 11 ? 1:
		Exe.BuildDate >= 20180314 ? 2:
		Exe.BuildDate >= 20110600 ? 3:
		                            4;

	let shrinkAddrs;
	if (style < 4)
	{
		$$(_, 9.2, `Find the common signature`)
		let reg = Exe.Version > 10 ? R32 : EAX;
		const prefix = MOV(reg, [ROC.StkReg, ROC.HasFP ? 8 : 4]); //mov regA, dword ptr [ARG.1]
		const csize = prefix.byteCount();

		const suffix =
			CMP(reg, 0xFB7)  //cmp regA, 0FB7h
		+	JL(WCp)          //jl short _nextcheck
		+	CMP(reg, 0xFBD)  //cmp regA, 0FBDh
		;

		const minCount = style === 1 ? 2 : 1;
		const maxCount = style === 1 ? 3 : 1;
		const addrs = Exe.FindHexN(minCount, maxCount, prefix + suffix);
		if (addrs.isEmpty())
			throw Error("Expected no of matches not found");

		let testerAddr;
		if (style === 1)
		{
			$$(_, 9.3, `Identify each based on whether retn 4 followed by same suffix is there within same function`)
			for (const memAddr of addrs)
			{
				if (Exe.FindHex(RETN(4) + suffix, memAddr + 0x10, memAddr + 0x100) > 0)
					shrinkAddrs = [memAddr + csize];
				else
					testerAddr = memAddr + csize;
			}
		}
		else //style 2 or 3
		{
			$$(_, 9.4, `For 2nd form, only one match would be there for the tester function`)
			testerAddr = addrs[0] + csize;
		}

		$$(_, 9.5, `If the register isnt EAX find the one that was used`)
		if (reg.isPlaceHolder())
			reg = R32.List[Exe.GetInt8(testerAddr + 1) & 0x7];

		$$(_, 9.6, `Construct the LUA caller code for Dwarf test`)
		const luaCaller = LUA.createCaller(["IsDwarf", AltFuncs[2]], "d>d", reg, EAX).join('');

		$$(_, 9.7, `Replace at the address`)
		Exe.SetHex( testerAddr
		,
			LUA.finalize(
				PUSH(EDX)  //push edx ; Backup
			+	luaCaller  //LUA function CALL
			+	POP(EDX)   //pop edx ; Restore it
			+	(ROC.HasFP
			?
				POP(EBP)   //pop ebp
			:
				''
			)
			+	RETN(4)    //retn 4
			,
				Exe.Phy2Vir(testerAddr, CODE)
			)
		);
	}

	if (!shrinkAddrs)
	{
		if (style > 2)
		{
			$$(_, 9.8, `Find the older form of the patterns`)
			const code =
				CMP(EAX, 0xFB7)  //cmp eax, 0FB7h
			+	JL(WCp)          //jl short _nextcheck
			+	MOV(ECX, R32)    //mov ecx, regB
			+	CALL(ALLWC)      //call CSession::GetJobID
			+	CMP(EAX, 0xFBD)  //cmp eax, 0FBDh
			;

			shrinkAddrs = Exe.FindHexN(1, 3, code);
			if (shrinkAddrs.isEmpty())
				throw Error("Expected no of shrinking code not found");
		}
		else if (style === 2)
		{
			$$(_, 9.9, `For 2nd style use the retn to find the correct function`)
			let code =
				RETN(4)          //retn 4
			+	CMP(R32, 0xFB7)  //cmp regA, 0FB7h
			+	JL(WCp)          //jl short _nextcheck
			+	CMP(R32, 0xFBD)  //cmp regA, 0FBDh
			;
			let addr = Exe.FindHex(code);
			if (addr < 0)
				throw Error("Reference pattern missing");

			$$(_, 9.10, `Now trace back to the beginning where the Dwarf test function is called`)
			code =
				PUSH(ESI)     //push esi
			+	CALL(ALLWC)   //call <IsDwarf>
			+	TEST(AL, AL)  //test al, al
			+	JZ(WCp)       //jz short _proceed
			;
			addr = Exe.FindLastHex(code, addr, addr - 0x100);
			if (addr < 0)
				throw Error("Shrinking function missing");

			shrinkAddrs = [addr];
		}
	}

	$$(_, 9.11, `Setup space to store the scale value`)
	const [, scaleAddr] = Exe.AddInt32(0);

	const found = shrinkAddrs.filter( (shrinkAddr, idx) =>
	{
		const __ = `${_} [${idx}]`;

		$$(__, 10.1, `Deduce the register containing the Job id`)
		const reg =
			style > 2   ? EAX :
			style === 2 ? ESI :
			              R32.List[Exe.GetUint8(shrinkAddr + 1) & 0x7];

		$$(__, 10.2, `Use it to create the LUA function Calling code`)
		const luaCaller = LUA.createCaller(["GetSprScale", AltFuncs[3]], "d>d", reg, [scaleAddr]).join('');

		if (style > 2) //Individual comparisons
		{
			$$(__, 10.3, `Ensure there is a JLE after comparison with FBD`)
			const addr = Exe.FindHex(CMP(EAX, 0xFBD), shrinkAddr);
			const ins = Instr.FromAddr(addr + 5);
			if (ins.Codes[0] !== 0x7E && ins.Codes[1] !== 0x8E)
				return false;

			$$(__, 10.4, `Extract the instruction at the address. It would be either an FLD DWORD PTR or MOVSS XMM0, DWORD PTR`)
			const tgtLoader = ins.getNext(ins.Immd);

			$$(__, 10.5, `Extract the instruction after it. Would be a FMUL dword ptr or MULSS XMM0, DWORD PTR`)
			let multiplier = tgtLoader.getNext();

			$$(__, 10.6, `Save the next address (if it's a JMP go to it's target instead)`)
			let endAddr = multiplier.NextAddr;
			if (Exe.GetUint8(endAddr) === 0xEB)
				endAddr += Exe.GetInt8(endAddr + 1) + 2;

			$$(__, 10.7, `Modify the multiplier code to ensure dword ptr is used and use the scaleAddr as displacement`)
			if (multiplier.Codes[0] === 0xDC)
				multiplier.Codes[0] = 0xD8;

			multiplier.Disp = scaleAddr;

			$$(__, 10.8, `Construct the code to replace with`)
			let code =
				PUSHAD                //pushad ; backup registers
			+	luaCaller             //Code which calls the lua function to get the scale
			+	POPAD                 //popad  ; restore registers

			+	tgtLoader             //fld/movss xmm0, dword ptr [LOCAL.x]
			+	MOV(EAX, [scaleAddr]) //mov eax, dword ptr [scaleAddr]
			+	TEST(EAX, EAX)        //test eax, eax
			+	JZ(multiplier.Size)   //jz short _skipover
			+	multiplier            //fmul/mulss xmm0, dword ptr [eax]
			;
			const csize = code.byteCount();

			$$(__, 10.9, `Ensure there is enough space for the code`)
			if ((endAddr - shrinkAddr) > (csize + 2))
			{
				$$(__, 10.10, `Append the NOPs/Short JMP to the end of the code`)
				const delta = endAddr - shrinkAddr - csize;
				code +=
					delta > 0x12
				?
					JMP(delta, 0)    //jmp short <endAddr>
				:                    //   OR
					NOPs(delta)      //multibyte NOPs
				;

				$$(__, 10.11, `Replace at the address`)
				Exe.SetHex(shrinkAddr, LUA.finalize(code, Exe.Phy2Vir(shrinkAddr, CODE)));
			}
			else
			{
				$$(__, 10.12, `Append the JMP`)
				code +=
					JMP(Filler(1)) //jmp <endAddr>
				;
				
				$$(__, 10.14, `Prepare the arguments for auto-hook`)
				const args =
				{
					allocSize : csize + 5,
					postProc : LUA.finalize,
					procArgs : {1 : Exe.Phy2Vir(endAddr, CODE)} //serves as 3rd argument to postProc
				};

				$$(_, 10.15, `Add our code and jump to it from shrinkAddr`)
				AutoHook(shrinkAddr, code, args);
			}
		}
		else //seperate function return after FLD
		{
			$$(__, 10.17, `Construct the new function`)
			const code =
				PUSHAD                //pushad ; backup registers
			+	luaCaller             //Code which calls the lua function to get the scale
			+	POPAD                 //popad  ; restore registers

			+	MOV(EAX, [scaleAddr]) //mov eax, dword ptr [scaleAddr]
			+	TEST(EAX, EAX)        //test eax, eax
			+	JNZ(7)                //jnz short _idxInc
			+	FLD1                  //fld1
			+	POP(reg)              //pop regA
			+	POP(EBP)              //pop ebp
			+	RETN(4)               //retn 4
			+	FLD([scaleAddr])      //fld dword ptr [scaleAddr]
			+	POP(reg)              //pop regA
			+	POP(EBP)              //pop ebp
			+	RETN(4)               //retn 4
			;

			$$(__, 10.18, `Replace at shrinkAddr`)
			Exe.SetHex(shrinkAddr, LUA.finalize(code, Exe.Phy2Vir(shrinkAddr, CODE)));
		}

		return true;
	});

	if (found.isEmpty())
		throw Error("Shrinking address not found");

	$$(_, 11, `Check with user if they want to copy the supporting files to the target area's data folder`)
	if (!Warp.TestMode)
		Exe.GetUserInput('$copyCJLub', D_Bool, "Copy Custom Job Lua", "Do you want the supporting Lub files copied to <b>'data'</b> folder when patch is applied?", true);

	return true;
};

///
/// \brief Disable for unsupported clients
///
CustomJobs.validate = function()
{
	/// 07-16: build-specific path in apply0716() handles the fundamentally different table structure.
	/// Phase 1: LoadJobNameTable (0xd70510) — job display names.
	/// Phase 2: CGameMode__InitJobSpriteNameTables (0xd662c0) — male + female sprite paths.
	/// Phase 3: Palette tables (0xF4C/0xF58, capacity 0x2B) + head tables (0x616C/0x6178, capacity 0xB).
	/// IMF: No separate IMF prefix table exists in 07-16 (removed/merged). PCImfs Lua loaded but not hooked.
	return IsPost2010();
};

///
/// \brief Build-specific implementation for 07-16 client.
///        Phase 1: LoadJobNameTable (job display names).
///        Phase 2: InitJobSpriteNameTables (male + female sprite paths).
///        Phase 3: InitJobSpriteNameTables (palette + head tables).
///        IMF: No separate IMF prefix table in 07-16 — removed or merged. PCImfs Lua still loaded.
///        Bypasses generic pattern matching that fails for 07-16's ESI-indirect table structure.
///
CustomJobs.apply0716 = function(_)
{
	$$(_, '0716.1', `Find ACOLYTE string for LoadJobNameTable`)
	let strAddr = Exe.FindText("ACOLYTE");
	if (strAddr < 0)
		throw Error("ACOLYTE string not found");

	$$(_, '0716.2', `Find its reference in LoadJobNameTable (offset 0x10 = job ID 4)`)
	const refAddr = Exe.FindHex(MOV([R32, 0x10], strAddr));
	if (refAddr < 0)
		throw Error("ACOLYTE reference missing");

	$$(_, '0716.3', `Extract the base reload instruction after it (MOV EAX,[ESI])`)
	let ins = Instr.FromAddr(refAddr).moveToNext();
	if (ins.Codes[0] !== 0x8B || ins.MRM.Mode === 3)
		throw Error("Expected MOV for base reload after ACOLYTE ref");

	const movIns = ins;
	const srcReg = ins.MRM.getReg('M');

	$$(_, '0716.4', `Find the capacity limit (0x1109) before the reference`)
	LANGTYPE.load();

	const limit = 0x1109;
	const limitAddr = Exe.FindLastHex(limit.toHex(), refAddr, refAddr - 0x800);
	if (limitAddr < 0)
		throw Error("Limit 0x1109 missing");

	$$(_, '0716.5', `Find the first table assignment pattern after the limit`)
	const prefix = MOV(R32, ins.Disp ? [srcReg, ins.Disp] : [srcReg]);
	const tableAddrs = [
		...Exe.FindHexN(1, prefix + MOV([R32], POS4WC), limitAddr + 4, limitAddr + 0x60),
		...Exe.FindHexN(1, prefix + MOV([R32, WCp], POS4WC), limitAddr + 4, limitAddr + 0x60),
		...Exe.FindHexN(1, prefix + MOV([R32, POS2WC], POS4WC), limitAddr + 4, limitAddr + 0x60)
	].sort();

	if (tableAddrs.isEmpty())
		throw Error("Starting table assignment missing");

	const hookAddr = tableAddrs[0] + movIns.Size;
	const baseReg = R32.List[Exe.GetInt8(hookAddr + 1) & 0x7];

	$$(_, '0716.6', `Walk table entries using FetchTillEnd with POP register as end marker`)
	let [endIns, retainer, overflow] = FetchTillEnd(hookAddr, 1, movIns, baseReg, -1, (ins) =>
		ins.Codes[0] >= 0x58 && ins.Codes[0] <= 0x5F // POP reg32 marks end of table section
	);

	if (overflow)
		throw Error("Table end not found (overflow)");

	$$(_, '0716.7', `Add POP to retainer and find epilog past trailing table entry`)
	const popHex = endIns.toString();
	retainer = retainer + popHex;

	let epilogIns = endIns.getNext();
	if (epilogIns.Codes[0] === 0xC7) // MOV [reg+disp],imm32 — trailing table entry after POP
		epilogIns = epilogIns.getNext();

	$$(_, '0716.8', `Get MaxJob from user`)
	const MaxJob = Exe.GetUserInput('$maxJob', D_Uint16, "Limit Input", "Enter the maximum no of Job IDs", 4500, {min: 4400, max: 10000, saveDefault: true});
	if (MaxJob === false)
		Cancel("No Max Limit specified");

	$$(_, '0716.8b', `Patch LoadJobNameTable capacity to accommodate MaxJob`)
	const origCap = 0x1109;
	const origCapBytes = origCap * 4; // 0x4424

	// Find all instances of 0x1109 in the resize code (between limitAddr-0x40 and hookAddr)
	const capAddrs = Exe.FindHexN(origCap.toHex(), limitAddr - 0x40, hookAddr);
	for (const addr of capAddrs)
		Exe.SetInt32(addr, MaxJob);

	// Find the byte-offset displacement (0x4424 = 0x1109 * 4) in the LEA else-branch
	const byteOffAddr = Exe.FindLastHex(origCapBytes.toHex(), limitAddr, limitAddr - 0x40);
	if (byteOffAddr >= 0)
		Exe.SetInt32(byteOffAddr, MaxJob * 4);

	$$(_, '0716.9', `Overwrite string with Lua function name`)
	const ReqJobName = this.overwrite("Baby Acolyte", "ReqPCJobName");

	$$(_, '0716.10', `Load LUA and generate replacement code`)
	LUA.load();

	// Full range [0, MaxJob] ensures ALL converted indices are populated.
	// The original code had separate ranges that covered the middle (45-4000) range
	// with Korean names. The Lua replacement must cover these too, especially for
	// Doram base jobs (4217-4315) which convert_job_to_trans_or_baby maps to
	// indices 267-365 — gap between 0x2C and 0xFA1 in the old range scheme.
	const limits = [
		[0, MaxJob]
	];

	const templates = this.generate(
		[["ReqPCJobName", ReqJobName], "dd>s", EDI, [LANGTYPE], EAX],
		null,
		[ESP, 0x24]
	);

	let parts = [
		PUSH(baseReg)
	+	PUSHAD
	];

	for (const template of templates)
	{
		for (const [min, max] of limits)
		{
			parts.push(SwapFillers(template, {1: min, 2: max}));
		}
	}

	parts.push(
		POPAD
	+	ADD(ESP, 4)
	);

	if (retainer)
		parts.push(retainer);

	parts.push(JMP(Filler(3)));

	let code = LUA.finalize(parts, Exe.Phy2Vir(hookAddr, CODE), {
		3: Exe.Phy2Vir(epilogIns.Addr, CODE)
	});

	$$(_, '0716.11', `Replace at hook address`)
	Exe.SetHex(hookAddr, code);

	// ==========================================================
	// Phase 2: InitJobSpriteNameTables — male + female sprite paths
	// ==========================================================

	$$(_, '0716.P2.1', `Overwrite strings for sprite path Lua functions`)
	const ReqPCPath = this.overwrite("Professor", "ReqPCPath");
	const MapPCPath = this.overwrite("Whitesmith", "MapPCPath");

	$$(_, '0716.P2.2', `Find male sprite table (LEA ESI,[EBX+0x5274])`)
	const maleLEA = Exe.FindHex("8D B3 74 52 00 00");
	if (maleLEA < 0)
		throw Error("Male sprite table LEA missing");

	$$(_, '0716.P2.3', `Verify base reload (MOV EAX,[ESI]) after EnsureStatusCapacity`)
	const maleMov = Instr.FromAddr(maleLEA + 18); // LEA(6) + PUSH(5) + MOV ECX,ESI(2) + CALL(5) = 18
	if (maleMov.Codes[0] !== 0x8B || maleMov.MRM.Mode === 3)
		throw Error("Expected MOV after male sprite EnsureStatusCapacity");

	const maleHookAddr = maleMov.NextAddr;
	const maleBaseReg = R32.List[Exe.GetInt8(maleHookAddr + 1) & 0x7];

	$$(_, '0716.P2.4', `Walk male sprite table (LEA ESI as end marker)`)
	let [maleEndIns, maleRetainer, maleOvf] = FetchTillEnd(maleHookAddr, 1, maleMov, maleBaseReg, -1,
		(ins) => ins.Codes[0] === 0x8D && ins.MRM.RegO === 6 // LEA ESI marks transition to female table
	);
	if (maleOvf)
		throw Error("Male sprite table end not found");

	$$(_, '0716.P2.5', `Generate sprite path templates`)
	// Full range — same reasoning as Phase 1 limits (see above).
	const sprLimits = [
		[0, MaxJob]
	];
	const sprTemplates = this.generate(
		[["ReqPCPath", ReqPCPath], "dd>s", EDI, [LANGTYPE], EAX],
		[["MapPCPath", MapPCPath], "dd>d", EDI, [LANGTYPE], EAX],
		[ESP, 0x24]
	);

	$$(_, '0716.P2.6', `Build and apply male sprite replacement code`)
	let maleParts = [PUSH(maleBaseReg) + PUSHAD];
	for (const tmpl of sprTemplates)
		for (const [min, max] of sprLimits)
			maleParts.push(SwapFillers(tmpl, {1: min, 2: max}));

	maleParts.push(POPAD + ADD(ESP, 4));
	if (maleRetainer) maleParts.push(maleRetainer);
	maleParts.push(JMP(Filler(3)));

	let maleCode = LUA.finalize(maleParts, Exe.Phy2Vir(maleHookAddr, CODE), {
		3: Exe.Phy2Vir(maleEndIns.Addr, CODE)
	});
	Exe.SetHex(maleHookAddr, maleCode);

	$$(_, '0716.P2.7', `Find female sprite table (PUSH 0x6D95 after male end)`)
	const femaleCapAddr = Exe.FindHex("68 95 6D 00 00", maleEndIns.Addr, maleEndIns.Addr + 40);
	if (femaleCapAddr < 0)
		throw Error("Female sprite capacity missing");

	const femaleMov = Instr.FromAddr(femaleCapAddr + 12); // PUSH(5) + MOV ECX,ESI(2) + CALL(5) = 12
	if (femaleMov.Codes[0] !== 0x8B || femaleMov.MRM.Mode === 3)
		throw Error("Expected MOV after female sprite EnsureStatusCapacity");

	const femaleHookAddr = femaleMov.NextAddr;
	const femaleBaseReg = R32.List[Exe.GetInt8(femaleHookAddr + 1) & 0x7];

	$$(_, '0716.P2.8', `Walk female sprite table (LEA from EBP as end marker)`)
	let [femaleEndIns, femaleRetainer, femaleOvf] = FetchTillEnd(femaleHookAddr, 1, femaleMov, femaleBaseReg, -1,
		(ins) => ins.Codes[0] === 0x8D && ins.MRM.Mode === 1 && ins.MRM.RegM === 5 // LEA reg,[EBP+disp8]
	);
	if (femaleOvf)
		throw Error("Female sprite table end not found");

	$$(_, '0716.P2.9', `Build and apply female sprite replacement code`)
	let femaleParts = [PUSH(femaleBaseReg) + PUSHAD];
	for (const tmpl of sprTemplates)
		for (const [min, max] of sprLimits)
			femaleParts.push(SwapFillers(tmpl, {1: min, 2: max}));

	femaleParts.push(POPAD + ADD(ESP, 4));
	if (femaleRetainer) femaleParts.push(femaleRetainer);
	femaleParts.push(JMP(Filler(3)));

	let femaleCode = LUA.finalize(femaleParts, Exe.Phy2Vir(femaleHookAddr, CODE), {
		3: Exe.Phy2Vir(femaleEndIns.Addr, CODE)
	});
	Exe.SetHex(femaleHookAddr, femaleCode);

	// ==========================================================
	// Phase 3: Expand palette + head table capacity to MaxJob
	// ==========================================================
	// Palette tables (this+0xF4C/0xF58, cap 43) and head tables
	// (this+0x616C/0x6178, cap 11) are too small for custom job indices.
	// Expand via small trampolines that replace PUSH cap with PUSH MaxJob.
	// Original hardcoded entries are preserved (Lua template loops can't be
	// used here — CLua::CallScriptFunction is broken on 07-16, same root
	// cause as Phase 8.3-8.4). Custom job indices get default fill value;
	// Phase 4 bounds check handles the fallback to index 0x0D.

	$$(_, '0716.P3.1', `Find and expand palette/head table capacities`)
	const p3TableLEAs = [
		{ leaHex: "8D B3 4C 0F 00 00", name: "PalMale"   },
		{ leaHex: "8D B3 58 0F 00 00", name: "PalFemale" },
		{ leaHex: "8D B3 6C 61 00 00", name: "HeadMale"  },
		{ leaHex: "8D B3 78 61 00 00", name: "HeadFemale" },
	];

	let p3EnsureCapVir = -1;

	for (let ti = 0; ti < 4; ti++) {
		const tbl = p3TableLEAs[ti];

		$$(_, `0716.P3.${ti+2}a`, `Find ${tbl.name} PUSH cap + CALL EnsureStatusCapacity`)
		const p3LeaAddr = Exe.FindHex(tbl.leaHex);
		if (p3LeaAddr < 0)
			throw Error(`${tbl.name} LEA not found`);

		// Pattern: LEA EAX,[EBP-0x18](3) + PUSH EAX(1) + PUSH imm8(2) + CALL(5)
		const p3PatAddr = Exe.FindHex("8D 45 E8 50 6A", p3LeaAddr + 6, p3LeaAddr + 50);
		if (p3PatAddr < 0)
			throw Error(`${tbl.name} EnsureStatusCapacity pattern not found`);

		const p3PushCapAddr = p3PatAddr + 4; // PUSH imm8 at offset 4 (after LEA+PUSH)
		const p3CallAddr = p3PushCapAddr + 2; // CALL at offset 6

		// Extract EnsureStatusCapacity VA (once)
		if (p3EnsureCapVir < 0) {
			const callImm = Exe.GetInt32(p3CallAddr + 1);
			p3EnsureCapVir = Exe.Phy2Vir(p3CallAddr + 5, CODE) + callImm;
		}

		$$(_, `0716.P3.${ti+2}b`, `Build ${tbl.name} capacity expansion trampoline`)
		// Trampoline: PUSH MaxJob (imm32) + CALL EnsureStatusCapacity + JMP back
		const p3BackVir = Exe.Phy2Vir(p3CallAddr + 5, CODE); // MOV EAX,[ESI] after original CALL

		const p3TrCode =
			PUSH(MaxJob) +                      // 68 XX XX 00 00 (5 bytes)
			CALL(Filler(1)) +                   // E8 rel32        (5 bytes)
			JMP(Filler(2));                     // E9 rel32        (5 bytes)

		const [p3TrPhys, p3TrVir] = Exe.Allocate(p3TrCode.byteCount(), 0x10);
		const p3Resolved = SetFillTargets(p3TrCode, {
			start: p3TrVir,
			1: p3EnsureCapVir,
			2: p3BackVir
		});
		Exe.SetHex(p3TrPhys, p3Resolved);

		// Replace PUSH imm8(2) + CALL(5) = 7 bytes with JMP(5) + NOP(2)
		$$(_, `0716.P3.${ti+2}c`, `Redirect ${tbl.name} to trampoline`)
		const p3PushCapVir = Exe.Phy2Vir(p3PushCapAddr, CODE);
		const p3Jmp = SetFillTargets(JMP(Filler(1)), {
			start: p3PushCapVir,
			1: p3TrVir
		});
		Exe.SetHex(p3PushCapAddr, p3Jmp + NOPs(2));
	}

	// ==========================================================
	// Phase 4: Expand bounds check in GetJobNameByClassAndGender
	// ==========================================================

	$$(_, '0716.P4.1', `Find bounds check pattern in GetJobNameByClassAndGender`)
	const boundsPattern = "83 F9 2B 7C 0B C7 02 0D 00 00 00 B9 0D 00 00 00";
	const boundsAddr = Exe.FindHex(boundsPattern);
	if (boundsAddr < 0)
		throw Error("GetJobNameByClassAndGender bounds check pattern not found");

	$$(_, '0716.P4.2', `Build bounds check trampoline`)
	const boundsOkVir = Exe.Phy2Vir(boundsAddr + 16, CODE); // instruction after 16-byte bounds block

	// Trampoline: allow [0, 0x2B) and [0xFA1, MaxJob), clamp all others to 0x0D
	// Also checks if the male palette table entry is non-NULL (prevents crash
	// when Lua files don't define the custom job — entry stays NULL after expansion)
	const trampCode =
		CMP(ECX, 0x2B) +                    // 83 F9 2B           (3 bytes)  byte 0
		JL(0x10) +                           // 7C 10 → ok_check   (2 bytes)  byte 3, target=21
		CMP(ECX, 0xFA1) +                    // 81 F9 A1 0F 00 00  (6 bytes)  byte 5
		JL(0x14) +                           // 7C 14 → clamp      (2 bytes)  byte 11, target=33
		CMP(ECX, MaxJob) +                   // 81 F9 XX XX 00 00  (6 bytes)  byte 13
		JGE(0x0C) +                          // 7D 0C → clamp      (2 bytes)  byte 19, target=33
		// ok_check: verify table entry is non-NULL before allowing through
		" A1 0C B3 5F 01" +                  // MOV EAX,[0x15fb30c] (5 bytes) byte 21 — male palette table ptr
		MOV(EAX, [4, ECX, EAX]) +            // MOV EAX,[ECX*4+EAX] (3 bytes) byte 26 — load entry
		TEST(EAX, EAX) +                     // TEST EAX,EAX        (2 bytes) byte 29
		JNZ(0x0B) +                          // JNZ → ok_exit       (2 bytes) byte 31, target=44
		// clamp: set default index 0x0D
		" C7 02 0D 00 00 00" +               // MOV [EDX], 0x0D     (6 bytes) byte 33
		" B9 0D 00 00 00" +                  // MOV ECX, 0x0D       (5 bytes) byte 39
		// ok_exit:
		JMP(Filler(5));                      // E9 rel32 → boundsOk (5 bytes) byte 44

	$$(_, '0716.P4.3', `Allocate and write trampoline`)
	const [trampPhys, trampVir] = Exe.Allocate(trampCode.byteCount(), 0x10);
	const resolvedTramp = SetFillTargets(trampCode, {
		start: trampVir,
		5: boundsOkVir
	});
	Exe.SetHex(trampPhys, resolvedTramp);

	$$(_, '0716.P4.4', `Redirect bounds check to trampoline`)
	const boundsVir = Exe.Phy2Vir(boundsAddr, CODE);
	const jmpToTramp = SetFillTargets(JMP(Filler(6)), {
		start: boundsVir,
		6: trampVir
	});
	Exe.SetHex(boundsAddr, jmpToTramp + NOPs(11));

	// ==========================================================
	// Phase 5: Fix convert_job_to_trans_or_baby subtraction
	// ==========================================================
	// The function subtracts 0xF6E (3950) from job IDs > 3950 to convert
	// baby/trans extended IDs to base form for sprite table lookup.
	// Custom job IDs get incorrectly subtracted, causing them to
	// index the wrong sprite (e.g. 4400-3950=450 → wrong job).
	// Fix: add upper bound check — skip subtraction for IDs >= 0x10F9 (4345),
	// which is above the highest standard job in any switch case (0x10F8).

	$$(_, '0716.P5.1', `Find baby subtraction pattern in convert_job_to_trans_or_baby`)
	// Pattern: CMP ECX, 0xF6E; JLE +6; SUB ECX, 0xF6E
	const babySubPattern = " 81 F9 6E 0F 00 00 7E 06 81 E9 6E 0F 00 00";
	const babySubAddr = Exe.FindHex(babySubPattern);
	if (babySubAddr < 0)
		throw Error("Baby subtraction pattern not found in convert_job_to_trans_or_baby");

	$$(_, '0716.P5.2', `Build subtraction fix trampoline`)
	const babySkipVir = Exe.Phy2Vir(babySubAddr + 14, CODE); // MOV EAX, ECX after the 14-byte block

	// Trampoline: add upper bound check for custom jobs
	const babyTrampCode =
		CMP(ECX, 0x10F9) +                  // 81 F9 F9 10 00 00  (6 bytes) — above max standard job
		JGE(Filler(1)) +                    // 0F 8D rel32         (6 bytes) → skip (use long JGE for Filler)
		CMP(ECX, 0xF6E) +                   // 81 F9 6E 0F 00 00  (6 bytes) — original check
		JLE(Filler(2)) +                    // 0F 8E rel32         (6 bytes) → skip
		SUB(ECX, 0xF6E) +                   // 81 E9 6E 0F 00 00  (6 bytes) — original subtraction
		JMP(Filler(3));                     // E9 rel32            (5 bytes) → back to MOV EAX, ECX

	$$(_, '0716.P5.3', `Allocate and write subtraction fix trampoline`)
	const [babyTrampPhys, babyTrampVir] = Exe.Allocate(babyTrampCode.byteCount(), 0x10);
	const resolvedBabyTramp = SetFillTargets(babyTrampCode, {
		start: babyTrampVir,
		1: babySkipVir,
		2: babySkipVir,
		3: babySkipVir
	});
	Exe.SetHex(babyTrampPhys, resolvedBabyTramp);

	$$(_, '0716.P5.4', `Redirect subtraction to trampoline`)
	const babySubVir = Exe.Phy2Vir(babySubAddr, CODE);
	const jmpToBabyTramp = SetFillTargets(JMP(Filler(7)), {
		start: babySubVir,
		7: babyTrampVir
	});
	Exe.SetHex(babySubAddr, jmpToBabyTramp + NOPs(9));

	// ==========================================================
	// Phase 6: Null resource pointer check in CalcDirectionFromDelta
	// ==========================================================
	// RenderAllLayers loads a sprite resource at actor+0x60 from child+0x410
	// (set by UpdateJobSpriteSprite virtual call). For custom jobs, this field
	// may be uninitialized (empty string), causing LoadResourceWithLock to
	// return NULL. The NULL is passed to CalcDirectionFromDelta as param_1,
	// then forwarded as 'this' to FindCellIndex → access violation crash.
	// Fix: add null check at CalcDirectionFromDelta entry.
	// If param_1 ([EBP+8]) is NULL, return 9 (default/unknown direction).

	$$(_, '0716.P6.1', `Find CalcDirectionFromDelta prologue`)
	// Pattern: PUSH EBP; MOV EBP,ESP; MOV EDX,[EBP+0x14]; MOV ECX,8; SUB ECX,[EBP+0xC]
	const calcDirPattern = " 55 8B EC 8B 55 14 B9 08 00 00 00 2B 4D 0C";
	const calcDirAddr = Exe.FindHex(calcDirPattern);
	if (calcDirAddr < 0)
		throw Error("CalcDirectionFromDelta prologue not found");

	$$(_, '0716.P6.2', `Build null check trampoline`)
	const calcDirBackVir = Exe.Phy2Vir(calcDirAddr + 6, CODE); // after the 6 replaced bytes (MOV ECX,8)

	const preNullCode =
		" 55" +                               // PUSH EBP                    (1 byte)
		" 8B EC" +                            // MOV EBP, ESP                (2 bytes)
		" 83 7D 08 00" +                      // CMP DWORD PTR [EBP+8], 0   (4 bytes)
		JE(Filler(1)) +                       // JE null_ptr                 (6 bytes)
		" 8B 55 14" +                         // MOV EDX, [EBP+0x14]        (3 bytes)
		JMP(Filler(2));                       // JMP back to MOV ECX,8      (5 bytes)

	const nullPtrCode =
		MOV(EAX, 9) +                         // MOV EAX, 9                  (5 bytes)
		" 5D" +                               // POP EBP                     (1 byte)
		" C3";                                // RET                         (1 byte)

	const fullCalcDirTrampCode = preNullCode + nullPtrCode;

	$$(_, '0716.P6.3', `Allocate and write null check trampoline`)
	const [calcDirTrampPhys, calcDirTrampVir] = Exe.Allocate(fullCalcDirTrampCode.byteCount(), 0x10);
	const nullPtrVir = calcDirTrampVir + preNullCode.byteCount();

	const resolvedCalcDirTramp = SetFillTargets(fullCalcDirTrampCode, {
		start: calcDirTrampVir,
		1: nullPtrVir,
		2: calcDirBackVir
	});
	Exe.SetHex(calcDirTrampPhys, resolvedCalcDirTramp);

	$$(_, '0716.P6.4', `Redirect CalcDirectionFromDelta to null check trampoline`)
	const calcDirVir = Exe.Phy2Vir(calcDirAddr, CODE);
	const jmpToCalcDirTramp = SetFillTargets(JMP(Filler(1)), {
		start: calcDirVir,
		1: calcDirTrampVir
	});
	Exe.SetHex(calcDirAddr, jmpToCalcDirTramp + NOPs(1));

	// ==========================================================
	// Phase 7: Generic Lua-based display name override
	// ==========================================================
	// Hook wrappers (GetJobNameByClassGender / GetJobName) at entry.
	// For custom job IDs (>= 0x10F9/4345) + display callers: look up
	// name from PCNames Lua table via Lua C API and write to output
	// std::string (MSVC SSO). No hardcoded job IDs or names — all
	// names come from Lua/lub files (PCFuncs.lub defines PCNames).
	// Sprite callers fall through to original wrapper code.
	//
	// lua_State* is stored in a global by Phase 9's trampoline.
	// If Phase 9 hasn't run yet (first frame), falls through safely.

	$$(_, '0716.P7.0', `Allocate global for lua_State pointer`)
	const [, g_luaState] = Exe.AddInt32(0);

	$$(_, '0716.P7.1', `Locate wrapper functions via CODE section offset`)
	const codeVirOff = Exe.Phy2Vir(boundsAddr, CODE) - boundsAddr;
	const wrapperInfo = [
		{ vir: 0xd5a1f0, name: "GetJobNameByClassGender" },
		{ vir: 0xd5a480, name: "GetJobName" }
	];
	for (const w of wrapperInfo) {
		w.phys = w.vir - codeVirOff;
		if (Exe.GetUint8(w.phys) !== 0x55 || Exe.GetUint8(w.phys + 3) !== 0x6A)
			throw Error(`Wrapper ${w.name} prologue mismatch at 0x${w.vir.toString(16)}`);
	}

	$$(_, '0716.P7.2', `Build Lua-based display name trampolines`)

	// Display caller return addresses (call_addr + 5) for each wrapper.
	// These 7 UI functions use the name for text display, NOT sprite loading.
	const displayRetAddrs = [
		[0x86bf6c, 0x79fbed, 0x7a1f0e, 0x8ef069, 0x91ca64, 0x885541, 0x869175],
		[0x86bfba, 0x79fc3b, 0x7a1f62, 0x8ef0c8, 0x91ca86, 0x885590, 0x8691c3]
	];

	// Lua C API addresses (07-16 specific, shared with Phase 9)
	const p7_lua_getfield  = 0x519DF0;
	const p7_lua_rawgeti   = 0x51A650;
	const p7_lua_tolstring = 0x51ACA0;
	const p7_lua_settop    = 0x51AAB0;

	for (let wi = 0; wi < 2; wi++) {
		const w = wrapperInfo[wi];
		const dispAddrs = displayRetAddrs[wi];
		let code = "";

		// --- Section 1: Check if custom job (>= 4345) ---
		code += " 81 7C 24 08 F9 10 00 00";  // CMP DWORD PTR [ESP+8], 0x10F9
		code += JB(Filler(50));                // JB fallthrough

		// --- Section 2: Check if display caller ---
		code += " 8B 04 24";                  // MOV EAX, [ESP]
		for (const addr of dispAddrs) {
			code += " 3D" + addr.toHex(4);     // CMP EAX, display_addr
			code += JE(Filler(60));             // JE lua_lookup
		}
		code += JMP(Filler(50));               // JMP fallthrough

		// --- Section 3: Lua lookup ---
		const luaLookupOff = code.byteCount();
		code += " 53 56 57";                  // PUSH EBX; PUSH ESI; PUSH EDI

		// Get lua_State*
		code += " A1" + g_luaState.toHex(4);  // MOV EAX, [g_luaState]
		code += " 85 C0";                     // TEST EAX, EAX
		code += JZ(Filler(70));                // JZ cleanup_fall
		code += " 8B D8";                     // MOV EBX, EAX (L)
		code += " 8B 7C 24 14";              // MOV EDI, [ESP+0x14] (job_id)

		// lua_getfield(L, LUA_GLOBALSINDEX, "PCNames")
		const p7PushStrOff = code.byteCount();
		code += " 68 00 00 00 00";            // PUSH &"PCNames" (fixup after alloc)
		code += " 68 EE D8 FF FF";           // PUSH LUA_GLOBALSINDEX (-10002)
		code += " 53";                        // PUSH EBX (L)
		code += CALL(Filler(91));              // CALL lua_getfield
		code += " 83 C4 0C";                 // ADD ESP, 12

		// lua_rawgeti(L, -1, jobid)
		code += " 57";                        // PUSH EDI (job_id)
		code += " 6A FF";                    // PUSH -1
		code += " 53";                        // PUSH EBX (L)
		code += CALL(Filler(92));              // CALL lua_rawgeti
		code += " 83 C4 0C";                 // ADD ESP, 12

		// lua_tolstring(L, -1, NULL)
		code += PUSH_0;                       // PUSH 0
		code += " 6A FF";                    // PUSH -1
		code += " 53";                        // PUSH EBX (L)
		code += CALL(Filler(93));              // CALL lua_tolstring
		code += " 83 C4 0C";                 // ADD ESP, 12

		// Save name in ESI
		code += " 89 C6";                    // MOV ESI, EAX

		// lua_settop(L, -3) — pop table + value
		code += " 6A FD";                    // PUSH -3
		code += " 53";                        // PUSH EBX (L)
		code += CALL(Filler(94));              // CALL lua_settop
		code += " 83 C4 08";                 // ADD ESP, 8

		// Check name valid
		code += " 85 F6";                    // TEST ESI, ESI
		code += JZ(Filler(70));               // JZ cleanup_fall
		code += " 80 3E 00";                // CMP BYTE PTR [ESI], 0
		code += JE(Filler(70));               // JE cleanup_fall

		// --- Section 4: Write name to output std::string (MSVC SSO) ---
		code += " 8B 4C 24 10";             // MOV ECX, [ESP+0x10] (output string*)

		// Zero buffer + set SSO capacity
		code += " 33 C0";                    // XOR EAX, EAX
		code += " 89 01";                    // MOV [ECX], EAX
		code += " 89 41 04";                // MOV [ECX+4], EAX
		code += " 89 41 08";                // MOV [ECX+8], EAX
		code += " 89 41 0C";                // MOV [ECX+0C], EAX
		code += " 89 41 10";                // MOV [ECX+10], EAX
		code += " C7 41 14 0F 00 00 00";    // MOV [ECX+14], 0x0F

		// Copy name (max 15 chars for SSO inline buffer)
		code += " 33 C0";                    // XOR EAX, EAX
		// copy_loop:
		code += " 8A 14 30";                // MOV DL, [EAX+ESI]
		code += " 88 14 01";                // MOV [ECX+EAX], DL
		code += " 84 D2";                   // TEST DL, DL
		code += " 74 05";                   // JZ copy_done (+5)
		code += " 40";                       // INC EAX
		code += " 3C 0F";                   // CMP AL, 0x0F
		code += " 72 F1";                   // JB copy_loop (-15)
		// copy_done:
		code += " 89 41 10";                // MOV [ECX+10], EAX (set size)

		// Return successfully
		code += " 5F 5E 5B";                // POP EDI; POP ESI; POP EBX
		code += " 8B C1";                   // MOV EAX, ECX
		code += " C2 10 00";                // RETN 0x10

		// --- Section 5: cleanup_fall ---
		const cleanupFallOff = code.byteCount();
		code += " 5F 5E 5B";                // POP EDI; POP ESI; POP EBX

		// --- Section 6: fallthrough (original prologue + JMP back) ---
		const fallthroughOff = code.byteCount();
		code += " 55 8B EC 6A FF";          // PUSH EBP; MOV EBP,ESP; PUSH -1
		code += JMP(Filler(1));              // JMP wrapper+5

		// --- Data: "PCNames" string ---
		const p7StrOff = code.byteCount();
		code += " 50 43 4E 61 6D 65 73 00"; // "PCNames\0"

		// --- Allocate and write trampoline ---
		$$(_, `0716.P7.${wi+1}a`, `Allocate wrapper ${wi+1} (${w.name}) trampoline`)
		const [trPhys, trVir] = Exe.Allocate(code.byteCount(), 0x10);
		const fills = {
			start: trVir,
			1:  w.vir + 5,
			50: trVir + fallthroughOff,
			60: trVir + luaLookupOff,
			70: trVir + cleanupFallOff,
			91: p7_lua_getfield,
			92: p7_lua_rawgeti,
			93: p7_lua_tolstring,
			94: p7_lua_settop
		};
		Exe.SetHex(trPhys, SetFillTargets(code, fills));

		// Fix up PUSH &"PCNames" (absolute address, not relative)
		Exe.SetInt32(trPhys + p7PushStrOff + 1, trVir + p7StrOff);

		// --- Redirect wrapper entry ---
		$$(_, `0716.P7.${wi+1}b`, `Redirect wrapper ${wi+1} entry to trampoline`)
		Exe.SetHex(w.phys, SetFillTargets(JMP(Filler(1)), { start: w.vir, 1: trVir }));
	}

	// ==========================================================
	// Phase 8: Fix CMode__GetJobSpriteIndex for custom jobs
	// ==========================================================
	// CMode__GetJobSpriteIndex (0xd5bb40) is used by UIBasicInfoWnd,
	// character select, and other UI for the English job name display.
	// Jobs in range [0xFA1, 0xFA1+0x7CE] (4001-5999) go through
	// C3dActorPC__GetJobClassType which transforms them to standard
	// job indices — custom jobs get wrong names (e.g. "Poring").
	// Fix: change 0x7CE to 0x157 (= 0x10F8-0xFA1) so custom jobs
	// (>= 0x10F9/4345) take the direct table lookup path instead,
	// where Phase 1 stored the Lua-defined name.
	// Pattern: LEA ECX,[EDX-0xFA1]; CMP ECX,0x7CE; JBE

	$$(_, '0716.P8.1', `Find GetJobSpriteIndex range check`)
	const sprIdxPattern = " 8D 8A 5F F0 FF FF 81 F9 CE 07 00 00 76";
	const sprIdxAddr = Exe.FindHex(sprIdxPattern);
	if (sprIdxAddr < 0)
		throw Error("GetJobSpriteIndex range check pattern not found");

	$$(_, '0716.P8.2', `Patch range threshold from 0x7CE to 0x157`)
	// CMP ECX, 0x7CE is at sprIdxAddr+6, immediate at sprIdxAddr+8
	Exe.SetInt16(sprIdxAddr + 8, 0x0157);

	// Phase 8.3-8.4: REMOVED — InitLuaResourceTables loop extension was a no-op.
	// CLua::CallScriptFunction is broken (stock client bug) — the loop never
	// successfully invokes ReqPCJobName regardless of iteration count.
	// Phase 9 bypasses this by calling Lua C API directly at query time.

	// ==========================================================
	// Phase 9: Lua C API code cave in GetJobSpriteIndex
	// ==========================================================
	// The 0xf88 display name table is never populated because
	// CLua::CallScriptFunction is broken in InitLuaResourceTables
	// (stock client bug — it never enters Lua for ReqPCJobName).
	// Fix: replace the direct table lookup for custom job IDs
	// (MOV EAX,[ESI+EDX*4] after Phase 8's range check) with a
	// JMP to a code cave that calls Lua C API directly:
	//   lua_getfield(L, LUA_GLOBALSINDEX, "PCNames")
	//   lua_rawgeti(L, -1, jobid)
	//   lua_tolstring(L, -1, NULL)
	// This runs at QUERY TIME when UI needs the name, so the
	// Lua state is valid and PCNames table is populated.

	$$(_, '0716.P9.1', `Locate MOV EAX,[ESI+EDX*4] after range check`)
	// MOV is 19 bytes after the LEA pattern found by Phase 8:
	// LEA(6) + CMP(6) + JBE(2) + CMP(3) + JBE(2) = 19
	const movAddr = sprIdxAddr + 19;
	const movBytes = Exe.GetHex(movAddr, 3);
	if (movBytes !== " 8B 04 96")
		throw Error("GetJobSpriteIndex MOV EAX,[ESI+EDX*4] not found at expected offset (got " + movBytes + ")");

	$$(_, '0716.P9.2', `Build Lua C API trampoline`)
	// Lua C API addresses (07-16 specific)
	const lua_getfield  = 0x519DF0;
	const lua_rawgeti   = 0x51A650;
	const lua_tolstring = 0x51ACA0;
	const lua_settop    = 0x51AAB0;

	let p9code = "";

	// Save registers
	p9code += " 53";                        // PUSH EBX
	p9code += " 51";                        // PUSH ECX
	p9code += " 52";                        // PUSH EDX (job ID)

	// Get CLua* from CGameMode (EDI = this)
	p9code += " 8B 87 B8 59 00 00";        // MOV EAX, [EDI+0x59B8]
	p9code += " 85 C0";                    // TEST EAX, EAX
	p9code += JZ(Filler(90));              // JZ fallback

	// Get lua_State* (first field of CLua struct)
	p9code += " 8B 00";                    // MOV EAX, [EAX]
	p9code += " 85 C0";                    // TEST EAX, EAX
	p9code += JZ(Filler(90));              // JZ fallback

	// EBX = lua_State*
	p9code += " 8B D8";                    // MOV EBX, EAX
	p9code += " 89 1D" + g_luaState.toHex(4); // MOV [g_luaState], EBX — save for Phase 7

	// lua_getfield(L, LUA_GLOBALSINDEX, "PCNames")
	// Note: PUSH needs an absolute address, not a Filler (which resolves
	// to a relative offset). We write a placeholder here and fix it up
	// with Exe.SetInt32 after allocation gives us the real VA.
	const p9PushStrOff = p9code.byteCount();
	p9code += " 68 00 00 00 00";          // PUSH &"PCNames" (placeholder, fixed after alloc)
	p9code += " 68 EE D8 FF FF";          // PUSH 0xFFFFD8EE (-10002 = LUA_GLOBALSINDEX)
	p9code += " 53";                       // PUSH EBX (L)
	p9code += CALL(Filler(91));            // CALL lua_getfield
	p9code += " 83 C4 0C";                // ADD ESP, 12

	// lua_rawgeti(L, -1, jobid)
	p9code += " FF 34 24";                // PUSH [ESP] (saved EDX = job ID)
	p9code += " 6A FF";                   // PUSH -1 (table at Lua stack top)
	p9code += " 53";                       // PUSH EBX (L)
	p9code += CALL(Filler(92));            // CALL lua_rawgeti
	p9code += " 83 C4 0C";                // ADD ESP, 12

	// lua_tolstring(L, -1, NULL) -> EAX = const char*
	p9code += PUSH_0;                      // PUSH 0 (len ptr = NULL)
	p9code += " 6A FF";                   // PUSH -1
	p9code += " 53";                       // PUSH EBX (L)
	p9code += CALL(Filler(93));            // CALL lua_tolstring
	p9code += " 83 C4 0C";                // ADD ESP, 12

	// Save result on stack (ECX/EDX are caller-saved, lua_settop clobbers them)
	p9code += " 50";                        // PUSH EAX (save tolstring result)

	// lua_settop(L, -3) — pop PCNames table + value from Lua stack
	p9code += " 6A FD";                   // PUSH -3
	p9code += " 53";                       // PUSH EBX (L)
	p9code += CALL(Filler(94));            // CALL lua_settop
	p9code += " 83 C4 08";                // ADD ESP, 8

	// Restore and check result
	p9code += " 58";                        // POP EAX (restore tolstring result)
	p9code += " 85 C0";                    // TEST EAX, EAX
	p9code += JZ(Filler(90));              // JZ fallback

	// Success: return EAX (char* to job name from Lua)
	p9code += " 5A 59 5B";                // POP EDX; POP ECX; POP EBX
	p9code += " 5F 5E";                   // POP EDI; POP ESI
	p9code += FP_STOP;                     // MOV ESP,EBP; POP EBP
	p9code += " C2 08 00";                // RET 8

	// Fallback: original table lookup (returns "Poring" etc)
	const p9FallbackOff = p9code.byteCount();
	p9code += " 5A 59 5B";                // POP EDX; POP ECX; POP EBX
	p9code += " 8B 04 96";                // MOV EAX, [ESI+EDX*4] (original)
	p9code += " 5F 5E";                   // POP EDI; POP ESI
	p9code += FP_STOP;                     // MOV ESP,EBP; POP EBP
	p9code += " C2 08 00";                // RET 8

	// Data: "PCNames" string
	const p9StrOff = p9code.byteCount();
	p9code += " 50 43 4E 61 6D 65 73 00"; // "PCNames\0"

	$$(_, '0716.P9.3', `Allocate and write Lua C API trampoline`)
	const [p9Phys, p9Vir] = Exe.Allocate(p9code.byteCount(), 0x10);

	const p9Fills = {
		start: p9Vir,
		90: p9Vir + p9FallbackOff,     // fallback label
		91: lua_getfield,              // CALL lua_getfield
		92: lua_rawgeti,               // CALL lua_rawgeti
		93: lua_tolstring,             // CALL lua_tolstring
		94: lua_settop                 // CALL lua_settop
	};
	Exe.SetHex(p9Phys, SetFillTargets(p9code, p9Fills));

	// Fix up the PUSH &"PCNames" with the absolute address
	// (Filler system computes relative offsets, but PUSH needs absolute)
	Exe.SetInt32(p9Phys + p9PushStrOff + 1, p9Vir + p9StrOff);

	$$(_, '0716.P9.4', `Redirect GetJobSpriteIndex table lookup to trampoline`)
	const movVir = Exe.Phy2Vir(movAddr, CODE);
	const p9Jmp = SetFillTargets(JMP(Filler(1)), {
		start: movVir,
		1: p9Vir
	});
	// Replace MOV(3) + epilogue(8) = 11 bytes with JMP(5) + NOPs(6)
	Exe.SetHex(movAddr, p9Jmp + NOPs(6));


	// ============================================================
	// Phase 10: Extend is_job_id_in_range for custom jobs
	// ============================================================
	// is_job_id_in_range (0xd9d290) checks [4332, 4349] (Summoner/Doram range).
	// GetJobSprNameEx uses the result to choose between:
	//   - In-range path: uses sprite name from table + is_doram_job_id for race dir
	//   - Not-in-range path: Korean fallback (wrong name for custom jobs)
	// Extending to [4332, MaxJob] makes custom jobs take the in-range path.
	// is_doram_job_id (separate function) correctly returns 0 for custom jobs,
	// so GetRaceNameShort selects human race (인간족) — not Doram (도람족).

	$$(_, '0716.P10.1', `Find is_job_id_in_range function`)
	const rangePattern =
		" 55 8B EC 8B 45 08"          // PUSH EBP; MOV EBP,ESP; MOV EAX,[EBP+8]
	+	" 05 14 EF FF FF"             // ADD EAX, -4332
	+	" 83 F8 11"                   // CMP EAX, 0x11 (17 = 4349-4332)
	+	" 0F 96 C0"                   // SETBE AL
	+	" 5D"                         // POP EBP
	+	" C2 04 00"                   // RET 4
	;
	const rangeAddr = Exe.FindHex(rangePattern);
	if (rangeAddr < 0)
		throw Error("is_job_id_in_range pattern not found");

	$$(_, '0716.P10.2', `Verify CC padding after function`)
	const paddingBytes = Exe.GetHex(rangeAddr + 21, 2);
	if (paddingBytes !== " CC CC")
		throw Error("Expected CC CC padding after is_job_id_in_range, got " + paddingBytes);

	$$(_, '0716.P10.3', `Patch range from [4332,4349] to [4332,MaxJob]`)
	// CMP EAX,imm8 (83 F8 11, 3 bytes) -> CMP EAX,imm32 (3D xx xx xx xx, 5 bytes)
	// Uses the 2 CC padding bytes for the extra 2 bytes. Total: 23 bytes.
	const newRangeFunc =
		" 55 8B EC 8B 45 08"          // PUSH EBP; MOV EBP,ESP; MOV EAX,[EBP+8]
	+	" 05 14 EF FF FF"             // ADD EAX, -4332
	+	" 3D 00 00 00 00"             // CMP EAX, imm32 (placeholder for MaxJob-4332)
	+	" 0F 96 C0"                   // SETBE AL
	+	" 5D"                         // POP EBP
	+	" C2 04 00"                   // RET 4
	;
	Exe.SetHex(rangeAddr, newRangeFunc);
	Exe.SetInt32(rangeAddr + 12, MaxJob - 4332);


	$$(_, '0716.12', `Add Lua file loaders`)
	const fileHookAddr = hookAddr + code.byteCount();
	LUA.addLoaders(
		[
			"Lua Files\\JobInfo\\PCIds",
			"Lua Files\\JobInfo\\PCPaths",
			"Lua Files\\JobInfo\\PCImfs",
			"Lua Files\\JobInfo\\PCHands",
			"Lua Files\\JobInfo\\PCPals",
			"Lua Files\\JobInfo\\PCNames",
			"Lua Files\\JobInfo\\PCFuncs"
		],
		"Lua Files\\DataInfo\\NPCIdentity",
		fileHookAddr
	);

	$$(_, '0716.13', `Ask about copying Lub files`)
	if (!Warp.TestMode)
		Exe.GetUserInput('$copyCJLub', D_Bool, "Copy Custom Job Lua", "Do you want the supporting Lub files copied to <b>'data'</b> folder when patch is applied?", true);

	return true;
};

///
/// \brief Extra steps when the patch is applied (Copy the Lua files if requested)
///
CustomJobs.onApplied = function()
{
	const _ = 'CustomJobs.onApplied';

	if (!Warp.TestMode && Exe.GetSavedInput('$copyCJLub'))
	{
		$$(_, 1.1, `Prepare the directory paths`)
		const suffix = "/Luafiles514/Lua Files/JobInfo";
		const srcDir = Warp.Path + "Inputs" + suffix;
		let tgtDir = System.DirPath(Warp.TgtExe) + "/data" + suffix;

		$$(_, 1.2, `For old clients the version prefix is not there`)
		if (Exe.BuildDate < 20120000)
			tgtDir = tgtDir.replace("LuaFiles514/", '');

		$$(_, 1.3, `Create the target directory`)
		const ready = System.MkDir(tgtDir);
		if (!ready)
			return;

		$$(_, 2, `Copy all the lua files to the target directory`)
		for (const prefix of
		[
			"PCIds",
			"PCPaths",
			"PCImfs",
			"PCHands",
			"PCPals",
			"PCNames",
			"PCFuncs"
		])
			System.Copy(srcDir + "/" + prefix + ".lub", tgtDir);
	}
};

///
/// \brief Helper function to replace the string with new function name and return it's VIRTUAL address
///
CustomJobs.overwrite = (oldStr, newStr) =>
{
	const _ = 'CustomJobs.overwrite';

	$$(_, 1, `Find the old string '${oldStr}'`)
	let addr = Exe.FindText(oldStr, PHYSICAL);

	/// For 07-16: job names are ALL UPPERCASE and many mixed-case strings are missing.
	/// Use alternative strings of sufficient length as overwrite targets.
	if (addr < 0 && Exe.BuildDate >= 20250700)
	{
		const altMap = {
			"Professor"     : "GUNSLINGER",       // 11 >= 10 (ReqPCPath)
			"Swordman"      : "SWORDMAN",          // 9 >= 9  (ReqPCImf)
			"Magician"      : "MAGICIAN",          // 9 >= 9  (ReqPCPal)
			"Swordman High" : "PORING_NOVICE",     // 14 >= 14 (ReqPCHandPath)
			"Baby Acolyte"  : "PORING_SNOVICE",    // 15 >= 13 (ReqPCJobName)
			"Whitesmith"    : "BLACKSMITH",         // 11 >= 10 (MapPCPath)
			"Assassin"      : "ASSASSIN",          // 9 >= 9  (MapPCImf)
			"Crusader"      : "CRUSADER",          // 9 >= 9  (MapPCPal)
			"Magician High" : "PECO_REBELLION",    // 15 >= 14 (MapPCHandPath)
			"High Wizard_W" : "PORING_TAEKWON",   // 15 >= 13 (MapPCJobName)
			"High Priest_W" : "PIG_WHITESMITH",    // 15 >= 14 (GetPCNameOvrd)
			"Alchemist"     : "ALCHEMIST",         // 10 >= 10 (GetHalter)
			"Acolyte"       : "ACOLYTE",           // 8 >= 8  (IsDwarf)
			"High Wizard"   : "ALCHEMIST_H",       // 12 >= 12 (GetSprScale)
		};
		const alt = altMap[oldStr];
		if (alt)
			addr = Exe.FindText(alt, PHYSICAL);
	}

	if (addr < 0)
		throw Error(`${oldStr} not found`);

	$$(_, 2, `Replace with the new one`)
	Exe.SetText(addr, newStr  + "\x00");

	$$(_, 3, `Return it's VIRTUAL address`)
	return Exe.Phy2Vir(addr);
};

///
/// \brief Helper function to generate the templates for Req/Get function & Map function
///
CustomJobs.generate = (firstSet, secondSet, memPtr) =>
{
	const _ = 'CustomJobs.generate';

	$$(_, 1, `Prepare the common parts`)
	const cmnPre =
		MOV(EDI, Filler(1))      //mov edi, startingValue ; serves as idx
	+	MOV(EBX, Filler(2))      //mov ebx, endingValue
	;

	const cmnSuf =
		(memPtr.length > 1 ? NOP2 : '') //add extra NOPs to accomodate for [esp + 24h] mem location
	+	MOV([4, EDI, ECX], EAX)  //mov dword ptr [edi*4 + ecx], eax
	+	INC(EDI)                 //inc edi ; _idxInc
	+	CMP(EDI, EBX)            //cmp edi, ebx
	;

	$$(_, 2, `Construct the templates in parts`)
	const templates = [
		firstSet,
		secondSet
	].map( (args, idx) =>
	{
		if (!args)
			return '';

		const [prep, main, restore] = LUA.createCaller(...args); ///feed the arguments to createCaller

		const prefix =
			cmnPre                    //edi & ebx assignment
		+	prep                      //Stack Prep
		;

		const infix =
			main                     //LUA caller code
		+	(idx === 0

		? //for Req/Get
			MOV(CL, [EAX])            //mov cl, byte ptr [EAX]
		+	TEST(CL, CL)              //test cl, cl
		+	JE(9)                     //je short _idxInc
		+	MOV(ECX, memPtr)          //mov ecx, dword ptr [memPtr]; //either direct address or ESP+24 ; 20 = 8 registers * 4 due to PUSHAD + 4 for the starting memory address which was PUSHed before the PUSHAD

		: //for Map
			TEST(EAX, EAX)            //test eax, eax
		+	JS(0xC)                   //js short _idxInc
		+	MOV(ECX, memPtr)          //mov ecx, dword ptr [memPtr] ;
		+	MOV(EAX, [4, EAX, ECX])   //mov eax, dword ptr [eax*4 + ecx]
		)
		+	cmnSuf                    //table assignment, EDI increment & comparison for loop
		;

		const csize = infix.byteCount();

		const suffix =
			JLE(-csize, 0)            //jle short _loop OR jle _loop ; to start of the 'main' code
		+	restore                   //Stack Restore
		;

		return (prefix + infix + suffix);
	});

	$$(_, 3, `Return the array`)
	return templates;
};
